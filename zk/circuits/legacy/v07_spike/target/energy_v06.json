{"noir_version":"1.0.0-beta.20+b4236c1957d0c26cb65d82adc9e5447b6ff1d629","hash":"6828852655356518811","abi":{"parameters":[{"name":"readings","type":{"kind":"array","length":100,"type":{"kind":"tuple","fields":[{"kind":"integer","sign":"unsigned","width":64},{"kind":"integer","sign":"unsigned","width":64}]}},"visibility":"private"},{"name":"exact_lat","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"exact_lon","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"light_level","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"tamper_flag","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"device_id","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"epoch_start_ts","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"coarse_lat","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"coarse_lon","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"}],"return_type":{"abi_type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},"error_types":{"361444214588792908":{"error_kind":"string","string":"attempt to multiply with overflow"},"14990209321349310352":{"error_kind":"string","string":"attempt to add with overflow"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"// InfraVeritas Energy Module v06 - Phase A.2.1\n// (without in-circuit ECDSA signature verification - that comes in A.2.2)\n\nfn main(\n    readings: [(u64, u64); 100],\n    exact_lat: u64,\n    exact_lon: u64,\n    light_level: u64,\n    tamper_flag: u64,\n    device_id: pub u64,\n    epoch_start_ts: pub u64,\n    coarse_lat: pub u64,\n    coarse_lon: pub u64\n) -> pub u64 {\n    // Anti-replay: timestamp in reasonable range (2023-09 .. 2033-05)\n    assert(epoch_start_ts >= 1700000000);\n    assert(epoch_start_ts <= 2000000000);\n\n    // Device ID: positive number, sane range\n    assert(device_id > 0);\n    assert(device_id < 1000000);\n\n    // Tamper detection: device must be intact\n    assert(tamper_flag == 0);\n\n    // Coordinate truncation: coarse must equal exact / 10000\n    // 48451700 microdegrees (48.4517 N) divided by 10000 = 4845 (0.01-degree grid)\n    assert(coarse_lat == exact_lat / 10000);\n    assert(coarse_lon == exact_lon / 10000);\n\n    // Compute total energy across 100 readings\n    let mut total_energy_mwh: u64 = 0;\n    for i in 0..100 {\n        let (voltage_mv, current_ma) = readings[i];\n        assert(voltage_mv <= 10000);\n        assert(current_ma <= 5000);\n        let power_mw = voltage_mv * current_ma / 1000;\n        total_energy_mwh = total_energy_mwh + power_mw;\n    }\n\n    // Light threshold: if dark, no generation is allowed\n    // Encoded as: (light_level < 50) implies (total_energy == 0)\n    // Boolean logic via arithmetic: is_dark * total_energy must be 0\n    let is_dark: u64 = if light_level < 50 { 1 } else { 0 };\n    assert(is_dark * total_energy_mwh == 0);\n\n    total_energy_mwh\n}\n","path":"/home/ppbar/infraveritas/aggregator/circuits/energy_v06/src/main.nr","function_locations":[{"start":365,"name":"main"}]}}}