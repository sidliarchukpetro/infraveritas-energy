{"noir_version":"1.0.0-beta.20+b4236c1957d0c26cb65d82adc9e5447b6ff1d629","hash":"6782797399393408257","abi":{"parameters":[{"name":"readings","type":{"kind":"array","length":50,"type":{"kind":"tuple","fields":[{"kind":"integer","sign":"unsigned","width":64},{"kind":"integer","sign":"unsigned","width":64}]}},"visibility":"private"},{"name":"device_id","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"epoch_start_ts","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"min_total_energy","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"}],"return_type":null,"error_types":{"361444214588792908":{"error_kind":"string","string":"attempt to multiply with overflow"},"14990209321349310352":{"error_kind":"string","string":"attempt to add with overflow"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"fn main(\n    readings: [(u64, u64); 50],\n    device_id: pub u64,\n    epoch_start_ts: pub u64,\n    min_total_energy: pub u64\n) {\n    // Anti-replay: timestamp in reasonable range\n    assert(epoch_start_ts >= 1700000000);\n    assert(epoch_start_ts <= 2000000000);\n    \n    // Device ID: positive number, not 0\n    assert(device_id > 0);\n    assert(device_id < 1000000);\n    \n    let mut total_energy_mwh: u64 = 0;\n    \n    for i in 0..50 {\n        let (voltage_mv, current_ma) = readings[i];\n        \n        assert(voltage_mv <= 10000);\n        assert(current_ma <= 5000);\n        \n        let power_mw = voltage_mv * current_ma / 1000;\n        total_energy_mwh += power_mw;\n    }\n    \n    assert(total_energy_mwh >= min_total_energy);\n}\n","path":"/home/ppbar/infraveritas/zk-learning/energy_v05/src/main.nr","function_locations":[{"start":126,"name":"main"}]}}}